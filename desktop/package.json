{
  "name": "@notecove/desktop",
  "version": "0.1.0",
  "description": "NoteCove Desktop Application",
  "main": "dist/main.js",
  "scripts": {
    "dev": "npm run build:main && concurrently \"npm run dev:renderer\" \"wait-on http://localhost:5173 && npm run dev:electron\"",
    "dev:renderer": "vite",
    "dev:electron": "cross-env NODE_ENV=development electron .",
    "build": "npm run build:renderer && npm run build:main",
    "rebuild": "npm run build",
    "build:renderer": "vite build",
    "build:main": "esbuild src/main.ts src/preload.ts --bundle --platform=node --outdir=dist --external:electron --external:fsevents",
    "build:dist": "npm run build && electron-builder",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:coverage": "c8 --reporter=html --reporter=text --exclude='tests/**' --exclude='dist/**' --exclude='**/*.spec.js' playwright test",
    "test:e2e:electron": "playwright test --project=electron",
    "test:e2e:electron:coverage": "c8 --reporter=html --reporter=text --exclude='tests/**' --exclude='dist/**' --exclude='**/*.spec.js' playwright test --project=electron",
    "coverage:report": "c8 report --reporter=html --reporter=text",
    "lint": "eslint . --ext .js,.ts",
    "lint:fix": "npm run lint -- --fix",
    "clean": "rimraf dist dist-electron coverage .nyc_output"
  },
  "dependencies": {
    "@tiptap/core": "^2.26.3",
    "@tiptap/extension-collaboration": "^2.26.3",
    "@tiptap/extension-image": "^2.26.3",
    "@tiptap/extension-table": "^2.26.3",
    "@tiptap/extension-table-cell": "^2.26.3",
    "@tiptap/extension-table-header": "^2.26.3",
    "@tiptap/extension-table-row": "^2.26.3",
    "@tiptap/extension-task-item": "^2.26.3",
    "@tiptap/extension-task-list": "^2.26.3",
    "@tiptap/pm": "^2.26.3",
    "@tiptap/starter-kit": "^2.26.3",
    "@tiptap/suggestion": "^2.26.3",
    "chokidar": "^3.6.0",
    "date-fns": "^2.30.0",
    "electron-store": "^8.1.0",
    "tippy.js": "^6.3.7",
    "uuid": "^9.0.1",
    "y-prosemirror": "^1.3.7",
    "yjs": "^13.6.27"
  },
  "devDependencies": {
    "@istanbuljs/nyc-config-typescript": "^1.0.2",
    "@playwright/test": "^1.40.1",
    "@types/chokidar": "^1.7.5",
    "@types/electron": "^1.4.38",
    "@types/node": "^20.19.21",
    "@types/uuid": "^9.0.8",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0",
    "c8": "^10.1.3",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^38.2.2",
    "electron-builder": "^24.9.1",
    "esbuild": "^0.25.10",
    "eslint": "^8.56.0",
    "jsdom": "^27.0.0",
    "rimraf": "^5.0.5",
    "source-map-support": "^0.5.21",
    "typescript": "^5.3.3",
    "vite": "^7.1.9",
    "vitest": "^3.2.4",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.notecove.desktop",
    "productName": "NoteCove",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "assets/**/*",
      "!dist-electron/**/*"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "build/icon.icns"
    },
    "win": {
      "target": "nsis",
      "icon": "build/icon.png"
    },
    "linux": {
      "target": "AppImage",
      "icon": "build/icon.png"
    }
  }
}
